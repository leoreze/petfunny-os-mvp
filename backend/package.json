{
  "name": "petfunny-os-backend",
  "version": "1.6.121",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:migrate": "node src/scripts/migrate.js",
    "db:seed": "node src/scripts/seed.js",
    "db:reset": "node src/scripts/reset.js",
    "push:keys": "node src/scripts/generateVapidKeys.js",
    "push:repair": "npm install web-push@3.6.7 asn1.js@5.4.1 http_ece@1.2.0 https-proxy-agent@7.0.6 jws@4.0.0 minimist@1.2.8 --save --no-audit --no-fund",
    "render:build": "npm install --omit=dev --omit=optional --no-audit --no-fund --legacy-peer-deps --progress=false && npm run db:migrate"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "optionalDependencies": {
    "asn1.js": "^5.4.1",
    "http_ece": "1.2.0",
    "https-proxy-agent": "^7.0.6",
    "jws": "^4.0.0",
    "minimist": "^1.2.8",
    "web-push": "^3.6.7"
  }
}
